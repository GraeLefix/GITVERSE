# ============================================================
# GITVERSE — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- LLM Providers (at least one required) ---

# Grok (xAI) — https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-3

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_REASONING_EFFORT=medium

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-pro

# Provider selection: auto | grok | openrouter | azure | google
GITREVERSE_QUICK_LLM=auto

# --- Embeddings (optional, for /library search) ---
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=512

# --- GitHub (optional, increases rate limits) ---
GITHUB_TOKEN=

# --- Supabase (optional, for prompt caching & library) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# --- Stripe (optional, for premium features) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
